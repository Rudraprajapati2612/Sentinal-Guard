# apps/webhook-dispatcher/.env
# Copy this to .env and fill in your values.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# Optional: shared secret between watcher and dispatcher
# If set, the watcher must send X-Sentinel-Secret: <value> header
# Add to watcher .env: WEBHOOK_SECRET=your_secret_here
DISPATCHER_API_SECRET=

# ── Discord (REQUIRED for demo) ───────────────────────────────────────────────
# How to get:
#   1. Open your Discord server
#   2. Go to a channel → Settings → Integrations → Webhooks
#   3. Create webhook → Copy Webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# ── Telegram (optional) ───────────────────────────────────────────────────────
# How to get bot token: message @BotFather on Telegram → /newbot
# How to get chat ID: message @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Circle (integration point — no public API yet) ────────────────────────────
# Leave empty unless you have a Circle compliance partnership
CIRCLE_API_KEY=
CIRCLE_API_URL=https://api.circle.com

# ── Wormhole (integration point — requires guardian partnership) ──────────────
# Leave empty for now — dispatcher will log the intent
WORMHOLE_API_KEY=
WORMHOLE_API_URL=https://api.wormholescan.io
