## 10. API Routes — Implementation Detail

### GET /api/alerts
```ts
// src/app/api/alerts/route.ts
import { sql } from '@/lib/db';
import { NextRequest, NextResponse } from 'next/server';

export async function GET(req: NextRequest) {
  const { searchParams } = new URL(req.url);
  const limit = parseInt(searchParams.get('limit') ?? '50');
  const offset = parseInt(searchParams.get('offset') ?? '0');
  const rule = searchParams.get('rule_triggered');
  const minSeverity = parseInt(searchParams.get('min_severity') ?? '0');

  const alerts = await sql`
    SELECT * FROM alerts
    WHERE severity >= ${minSeverity}
    ${rule ? sql`AND rule_triggered = ${rule}` : sql``}
    ORDER BY created_at DESC
    LIMIT ${limit} OFFSET ${offset}
  `;
  
  const [{ count }] = await sql`SELECT COUNT(*) FROM alerts`;
  
  return NextResponse.json({ alerts, total: parseInt(count) });
}
```

### GET /api/protocol-status
```ts
// Deserialize SentinelState account from Solana RPC
// SentinelState layout:
//   [0..8]   discriminator (skip)
//   [8..40]  protocol_address: Pubkey
//   [40]     paused: bool
//   [41..49] pause_count: u64 LE
//   [49..57] last_pause_ts: i64 LE
//   [57..65] escrow_balance: u64 LE
//   [65..97] authority: Pubkey
//   [97]     bump: u8

import { Connection, PublicKey } from '@solana/web3.js';

export async function GET() {
  const conn = new Connection(process.env.SOLANA_RPC_URL!);
  const pda = new PublicKey(process.env.SENTINEL_STATE_PDA!);
  
  const account = await conn.getAccountInfo(pda);
  if (!account) return NextResponse.json({ error: 'Not found' }, { status: 404 });
  
  const data = account.data;
  const protocol_address = new PublicKey(data.slice(8, 40)).toBase58();
  const paused = data[40] === 1;
  const pause_count = Number(data.readBigUInt64LE(41));
  const last_pause_ts = Number(data.readBigInt64LE(49));
  const escrow_balance = Number(data.readBigUInt64LE(57));
  const authority = new PublicKey(data.slice(65, 97)).toBase58();
  
  return NextResponse.json({
    protocol_address, paused, pause_count,
    last_pause_ts, escrow_balance, authority
  });
}
```

### POST /api/dispatch (webhook receiver)
```ts
// Receives AlertEvent JSON from Rust watcher
// Store in a simple in-memory ring buffer for real-time feed
// Also works if DB insert is preferred

const recentAlerts: any[] = []; // max 100

export async function POST(req: Request) {
  const alert = await req.json();
  recentAlerts.unshift(alert);
  if (recentAlerts.length > 100) recentAlerts.pop();
  console.log('[Webhook] Alert received:', alert.alert_id_hex?.slice(0, 16));
  return Response.json({ ok: true });
}

export async function GET() {
  return Response.json({ alerts: recentAlerts });
}
```

### POST /api/unpause
```ts
// Build and send unpause_withdrawals instruction
// Anchor discriminator: sha256("global:unpause_withdrawals")[..8]
// Accounts: sentinel_state (mut), protocol_authority (signer)

import { createHash } from 'crypto';
import {
  Connection, Keypair, PublicKey,
  Transaction, TransactionInstruction
} from '@solana/web3.js';
import * as fs from 'fs';

export async function POST() {
  const conn = new Connection(process.env.SOLANA_RPC_URL!);
  const keypairPath = process.env.PROTOCOL_AUTHORITY_KEYPAIR_PATH!;
  const keypair = Keypair.fromSecretKey(
    new Uint8Array(JSON.parse(fs.readFileSync(keypairPath, 'utf8')))
  );
  
  const disc = createHash('sha256')
    .update('global:unpause_withdrawals')
    .digest()
    .subarray(0, 8);
    
  const sentinelState = new PublicKey(process.env.SENTINEL_STATE_PDA!);
  const programId = new PublicKey(process.env.SENTINEL_PROGRAM_ID!);
  
  const ix = new TransactionInstruction({
    programId,
    data: Buffer.from(disc),
    keys: [
      { pubkey: sentinelState, isSigner: false, isWritable: true },
      { pubkey: keypair.publicKey, isSigner: true, isWritable: false },
    ]
  });
  
  const tx = new Transaction().add(ix);
  tx.feePayer = keypair.publicKey;
  tx.recentBlockhash = (await conn.getLatestBlockhash()).blockhash;
  tx.sign(keypair);
  
  const sig = await conn.sendRawTransaction(tx.serialize());
  await conn.confirmTransaction(sig, 'confirmed');
  
  return Response.json({ ok: true, signature: sig });
}
```

