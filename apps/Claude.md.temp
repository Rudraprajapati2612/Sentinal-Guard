## 3. File Structure

```
src/
  app/
    layout.tsx                    # fonts, metadata, global styles
    page.tsx                      # landing page (public, no auth)
    dashboard/
      layout.tsx                  # sidebar + topbar shell
      page.tsx                    # main dashboard
    alerts/
      page.tsx                    # full alert history
    analytics/
      page.tsx                    # charts and stats
    controls/
      page.tsx                    # unpause, configure
    api/
      alerts/route.ts             # GET alerts from PostgreSQL
      tvl/route.ts                # GET tvl_snapshots
      protocol-status/route.ts    # GET SentinelState from Solana RPC
      dispatch/route.ts           # POST webhook receiver from Rust watcher
      unpause/route.ts            # POST unpause_withdrawals instruction

  components/
    landing/
      Hero.tsx
      HowItWorks.tsx
      LiveDemo.tsx
      Architecture.tsx
      Stats.tsx
      RuleExplainer.tsx
      Footer.tsx
    dashboard/
      Sidebar.tsx
      Topbar.tsx
      StatsRow.tsx
      TVLChart.tsx
      AlertFeed.tsx
      ProtocolPanel.tsx
      AlertTable.tsx
      AlertModal.tsx
    shared/
      AddressBadge.tsx            # truncate + copy to clipboard
      SeverityBadge.tsx           # CRITICAL/HIGH/MEDIUM/LOW badge
      SeverityBar.tsx             # 0-100 progress bar colored
      RuleBadge.tsx               # FLASH_LOAN_DRAIN etc.
      StatusIndicator.tsx         # PAUSED / ACTIVE / WATCHING dot
      ExplorerLink.tsx            # Solana Explorer with cluster param
      LoadingSkeleton.tsx

  lib/
    db.ts                         # postgres.js client
    solana.ts                     # RPC client + SentinelState deserializer
    types.ts                      # all shared TypeScript types
    utils.ts                      # formatUSD, timeAgo, truncateAddress, etc.
    constants.ts                  # program IDs, PDA addresses
```

